---
// Lecture pages for section-child lectures. Landing-paired lectures (2-segment
// sectionRef) render at the unit-level route ([unit]/lecture/) instead — the
// June 6, 2026 uniform link-and-serve decision gives every lecture its own
// page; none embeds on a Commentary page.
import { getCollection, getEntry } from 'astro:content';
import LecturePage from '../../../../../../components/LecturePage.astro';
import { splitCommentaryId, normalizeId, isVisible } from '../../../../../../lib/site';

export async function getStaticPaths() {
  const lectures = (await getCollection('lectures')).filter(isVisible);
  const paths = [];
  for (const lecture of lectures) {
    const refId = normalizeId(lecture.data.sectionRef.id);
    // Landing-paired lecture (2-segment id) renders at the unit-level lecture route.
    if (refId.split('/').length < 3) continue;
    const section = await getEntry('commentary', refId);
    if (!section || !isVisible(section)) continue;
    const { book, unit, section: sec } = splitCommentaryId(section.id);
    paths.push({ params: { book, unit, section: sec }, props: { lecture, section } });
  }
  return paths;
}
const { lecture, section } = Astro.props;
---
<LecturePage lecture={lecture} section={section} />
