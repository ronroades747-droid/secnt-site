---
import { getCollection, render } from 'astro:content';
import Diagram from '../../../../../components/Diagram.astro';
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import UnitNav from '../../../../../components/UnitNav.astro';
import PrevNext from '../../../../../components/PrevNext.astro';
import PageDates from '../../../../../components/PageDates.astro';
import Breadcrumb from '../../../../../components/Breadcrumb.astro';
import { splitCommentaryId, normalizeId, lectureUrl, volumeUrl, commentaryUrl, isVisible } from '../../../../../lib/site';

export async function getStaticPaths() {
  const sections = (await getCollection('commentary'))
    .filter((e) => e.data.sectionType !== 'unit-landing' && isVisible(e));
  const lectures = await getCollection('lectures');
  return sections.map((entry) => {
    const { book, unit, section } = splitCommentaryId(entry.id);
    const lecture = lectures.find((l) => normalizeId(l.data.sectionRef.id) === entry.id);
    return { params: { book, unit, section }, props: { entry, lecture } };
  });
}
const { entry, lecture } = Astro.props;
const { book, unit } = splitCommentaryId(entry.id);
const unitId = `${book}/${unit}`;
const { Content } = await render(entry);
const d = entry.data;
// Paired-lecture link renders at the TOP of the article (in the page header),
// resolved from the section's hasLecture flag and the lecture's visibility.
const pairedLecture = d.hasLecture && lecture && isVisible(lecture) ? lecture : null;
const pairedLectureUrl = lectureUrl(entry.id);
const lectureNo = pairedLecture?.data.title.match(/^Lecture\s+(\d+)/)?.[1];
const diagramTop = d.diagram && d.diagram.position === 'top';
const diagramBottom = d.diagram && d.diagram.position === 'bottom';

const vols = await getCollection('volumes');
const bookDisplay = vols.find((v) => v.data.book === book)?.data.bookDisplay ?? book;
const crumbs = [
  { label: 'Commentaries', href: '/commentary/' },
  { label: bookDisplay, href: volumeUrl(book) },
  { label: d.passageRef ? `${bookDisplay} ${d.passageRef}` : unit, href: commentaryUrl(unitId) },
  { label: d.title },
];
---
<BaseLayout title={d.title} description={d.description}
  pageMeta={{ date: d.date, revised: d.revised, license: d.license, passageRef: d.passageRef }}>
  <div class="unit-layout">
  <UnitNav unitId={unitId} currentId={entry.id} />
  <article class="reading">
    <Breadcrumb crumbs={crumbs} />
    {d.passageRef && <p class="passage-ref">John {d.passageRef}</p>}
    <h1>{d.title}</h1>
    {d.greekEpigraph && <p class="greek-epigraph">{d.greekEpigraph}</p>}

    {pairedLecture && (
      <p class="paired-lecture">
        <a href={pairedLectureUrl}>Watch the paired lecture{lectureNo ? ` \u2014 Lecture ${lectureNo}` : ''}</a>
      </p>
    )}

    {diagramTop && <Diagram diagram={d.diagram} entryPath={entry.filePath} />}

    <Content />

    {diagramBottom && <Diagram diagram={d.diagram} entryPath={entry.filePath} />}

    <PrevNext unitId={unitId} currentId={entry.id} />
    <PageDates date={d.date} revised={d.revised} />
  </article>
  </div>
</BaseLayout>
