---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE, commentaryUrl, articleUrl, isVisible } from '../lib/site';
const volumes = (await getCollection('volumes'))
  .filter(isVisible)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
// Parent articles only (chapters excluded); gated so the homepage shows an
// Articles entry point only once an article is published — the home page is
// the front door to both genres, distinct from /commentary/ (volumes only)
// and /articles/ (articles only), never showing an empty "coming" section.
const articles = (await getCollection('articles'))
  .filter((a) => !a.id.includes('/') && isVisible(a))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout
  title={SITE.wordmark}
  description="Verse-by-verse commentary on the New Testament at the systematic-theological register, paired with audiovisual lectures. Freely available under CC BY 4.0."
  tier="1"
>
  <div class="reading reading--wide">
    <h1>{SITE.name}</h1>
    <p>
      A multi-volume, verse-by-verse commentary on the New Testament. The
      published Commentary is paired, section by section, with audiovisual
      Lectures that teach the same scholarly work — the writing for readers at
      depth, the lectures for teachers and students. The series is freely
      available under a Creative Commons Attribution 4.0 license.
    </p>
    <p>
      SECNT is also an invitation into a new genre of biblical scholarship. The
      Commentary teaches the text’s own compositional architecture — the
      deliberate shape of the writing — as part of what it sets before the
      reader, not as work kept behind the page. And it is unusual in how it is
      made: every position is adjudicated and locked by a named, accountable
      editor, working in a method explained openly on these pages — the
      human-accountable use of assistance toward which scholarship across many
      fields is already trending. Begin with
      <a href="/architecture-principles/">Architecture Principles</a> and
      <a href="/methodology/">Methodology</a>, and read not only what the series
      concludes but how it reaches its conclusions.
    </p>

    <blockquote class="editor-welcome">
      <p>But most of all, my prayer is that God will speak to you and give you clarity as you seek to know Him better through our commentaries.</p>
      <footer>— Ronald E. Roades, BA, MA (Wheaton College)<br />Chief Editor, SECNT<br /><a href="mailto:editor@secnt.org">editor@secnt.org</a></footer>
    </blockquote>

    <h2>Volumes</h2>
    <ul>
      {volumes.map((v) => (
        <li><a href={commentaryUrl(v.id)}>{v.data.title}</a></li>
      ))}
      {volumes.length === 0 && <li><a href="/commentary/john/">Commentary on the Gospel of John</a></li>}
    </ul>

    {articles.length > 0 && (
      <Fragment>
        <h2>Articles</h2>
        <ul>
          {articles.map((a) => (
            <li><a href={articleUrl(a.id)}>{a.data.title}</a></li>
          ))}
        </ul>
      </Fragment>
    )}

    <h2>About the series</h2>
    <ul>
      <li><a href="/about/">About SECNT</a></li>
      <li><a href="/architecture-principles/">Architecture Principles</a></li>
      <li><a href="/methodology/">Methodology</a></li>
      <li><a href="/citing/">Citing</a></li>
    </ul>
  </div>
</BaseLayout>
