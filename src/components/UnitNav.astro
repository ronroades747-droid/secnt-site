---
// Persistent unit navigation (sections sidebar): the unit landing
// ("Introduction") plus every PUBLISHED section, grouped under segment
// subheads (June 6, 2026 navigation handoff, Change 4), the current page in
// gold. This is a pure reading spine — the paired-lecture link lives at the
// TOP of each Commentary page (in the article header), not in the rail.
//
// Count- and draft-aware via isVisible. Shows the "more to come" note (driven
// by the landing's passageComplete) at the foot while the passage is in
// progress. Mobile: the nav stacks above the article and the sections list
// scrolls; desktop: the sidebar scrolls independently when it exceeds the
// viewport.
import { getCollection } from 'astro:content';
import { commentaryUrl, isVisible, SEGMENT_ORDER, SEGMENT_OF } from '../lib/site';

interface Props {
  unitId: string; // e.g. "john/1-1-to-3"
  currentId?: string; // section id, or undefined on the landing
}
const { unitId, currentId } = Astro.props;

const all = await getCollection('commentary');
const landing = all.find((e) => e.id === unitId);
const sections = all
  .filter((e) => e.id.startsWith(unitId + '/') && isVisible(e))
  .sort((a, b) => a.data.sectionNumber - b.data.sectionNumber);

type Item = { id: string; url: string; label: string };
const groups = new Map<string, Item[]>();
const add = (segment: string, item: Item) => {
  if (!groups.has(segment)) groups.set(segment, []);
  groups.get(segment)!.push(item);
};

if (landing && isVisible(landing)) {
  add(SEGMENT_OF['unit-landing'], {
    id: landing.id,
    url: commentaryUrl(landing.id),
    label: 'Introduction',
  });
}
for (const s of sections) {
  add(SEGMENT_OF[s.data.sectionType] ?? 'Exegesis', {
    id: s.id,
    url: commentaryUrl(s.id),
    label: s.data.title,
  });
}

// Segments render in canonical order; empty segments are skipped, so the
// sidebar grows segment by segment as pairs publish.
const orderedGroups = SEGMENT_ORDER.filter((seg) => groups.has(seg)).map(
  (seg) => ({ segment: seg, items: groups.get(seg)! })
);

const current = currentId ?? unitId;
const showMore = landing ? landing.data.passageComplete !== true : true;
const hasAny = orderedGroups.length > 0;
---
{hasAny && (
  <nav class="unit-nav" aria-label="Sections in this unit">
    <div class="unit-nav__sections">
      <p class="unit-nav__heading">Sections</p>
      {orderedGroups.map((g) => (
        <div class="unit-nav__segment">
          <p class="unit-nav__subhead">{g.segment}</p>
          <ol>
            {g.items.map((it) => (
              <li>
                {it.id === current ? (
                  <span class="unit-nav__current" aria-current="page">{it.label}</span>
                ) : (
                  <a href={it.url}>{it.label}</a>
                )}
              </li>
            ))}
          </ol>
        </div>
      ))}
      {showMore && <p class="unit-nav__more">More to come; check back soon.</p>}
    </div>
  </nav>
)}
