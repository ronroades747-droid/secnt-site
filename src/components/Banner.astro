---
import { SITE } from '../lib/site';
// Chrome banner — two heights, one image:
//   full (default) — Tier-1 arrival points (homepage, volume, section homes);
//     21:9, descriptive alt, per the Visual Register.
//   slim           — every other page; a persistent ~110px strip carrying the
//     warm-scholarly signature without competing with reading content. The
//     strip is decorative identity (empty alt — the full banner already carries
//     the description at the arrival points).
// Source: /public/banner.jpg (the Deep in God's Word library image),
// center-cropped so the scholars-at-study and arched-doorway focal areas survive.
interface Props { slim?: boolean; }
const { slim = false } = Astro.props;
---
<div class={slim ? 'banner banner--slim' : 'banner'}>
  <img
    src={SITE.banner.src}
    alt={slim ? '' : SITE.banner.alt}
    width="2100"
    height="900"
    loading="eager"
    decoding="async"
  />
</div>
