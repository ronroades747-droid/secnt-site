---
import { SITE } from '../lib/site';
// Bunny Stream responsive embed. Library id is a site constant; the per-video
// GUID comes from lecture frontmatter (bunnyVideoId).
interface Props { videoId: string; title: string; }
const { videoId, title } = Astro.props;
const src = `https://iframe.mediadelivery.net/embed/${SITE.bunnyLibraryId}/${videoId}?autoplay=false&preload=false`;
---
<div class="video-embed">
  <iframe
    src={src}
    title={title}
    loading="lazy"
    allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture; fullscreen"
    allowfullscreen
  ></iframe>
</div>
